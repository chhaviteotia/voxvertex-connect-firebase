# Backend env – copy to .env in this directory (or use root .env)
# See repo root .env.example for full list.

PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/voxvertex
DB_ADAPTER=mongodb
DB_FALLBACK_TO_MONGODB=true
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
AUTH_PROVIDER=jwt
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
STORAGE_PROVIDER=cloudinary
# Comma-separated allowed frontend origins in production
# CORS_ORIGIN=https://your-frontend-domain.vercel.app
# Auth rate limit settings
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=10
# AUTH_PROVIDER=firebase to verify Firebase ID tokens on protected routes
# DB_ADAPTER=mongodb (default) or aws to use AWS adapter
# DB_ADAPTER=firebase is reserved for Firebase-native repositories; if unavailable, fallback uses MongoDB when DB_FALLBACK_TO_MONGODB=true
# STORAGE_PROVIDER=firebase uses Firebase Storage first and falls back to Cloudinary if upload fails

# Cloudinary (for profile photo upload)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
