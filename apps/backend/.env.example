# Copy to apps/backend/.env for local dev (not loaded in deployed Cloud Functions).

NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/voxvertex
JWT_SECRET=use-a-long-random-string-in-production

# Required in production (Firebase Console → Functions → api → Environment variables)
# FRONTEND_URL=https://YOUR_PROJECT_ID.web.app

# Optional: restrict CORS (comma-separated origins). Leave empty to allow any origin.
# CORS_ORIGIN=https://YOUR_PROJECT_ID.web.app

# Password reset emails (optional; without SMTP, reset links are only logged in non-production)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com
