# Backend env – copy to .env in this directory (or use root .env)
# See repo root .env.example for full list.

PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/voxvertex
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
# Comma-separated allowed frontend origins in production
# CORS_ORIGIN=https://your-frontend-domain.vercel.app
# Auth rate limit settings
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=10
# DB_ADAPTER=mongodb (default) or aws to use AWS adapter

# Cloudinary (for profile photo upload)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
