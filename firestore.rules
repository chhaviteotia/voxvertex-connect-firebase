rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * All application data is read/written only by the Cloud Functions API
     * (Firebase Admin SDK). The web client uses JWT auth against Express and
     * never talks to Firestore directly. Deny public client access.
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
